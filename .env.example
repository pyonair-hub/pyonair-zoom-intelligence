# Zoom Intelligence - Environment Variables
# Copy this file to .env and fill in your values.

# Recall.ai API
RECALL_API_KEY=your_recall_api_key_here
RECALL_API_BASE=https://us-west-2.recall.ai/api/v1

# Anthropic (Claude) API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Application
HOST=0.0.0.0
PORT=8900
LOG_LEVEL=info

# Demo mode: true = uses simulated transcript stream instead of live Recall.ai
DEMO_MODE=true

# Bot display name shown in meetings
BOT_DISPLAY_NAME=Pyonair AI

# Post-meeting email (optional)
SUMMARY_EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
